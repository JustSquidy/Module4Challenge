@page
@model Module4Challenge.Pages.DadJokesModel
@{
    ViewData["Title"] = "Dad Joke Generator";
}

<div class="container mt-4">
@* This is the title on the Dad Jokes page *@
    <div class="text-center mb-4">
        <h1 class="display-4">Welcome to the Dad Joke Generator</h1>
        <p class="text-muted">Clean funny dad jokes!.</p> 
    </div>
@* This function displays two dad jokes that are chosen randomly when the more jokes button is pressed *@
    <div class="row">
        @for (int i = 0; i < Model.CurrentJokes.Length; i++)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Dad Joke #@(i + 1)</h5>
                        <p class="card-text">@Model.CurrentJokes[i]</p>
                    </div>
                </div> 
            </div>
        }
    </div>

    <form method="post" class="text-center mt-3"> 
        <button type="submit" class="btn btn-primary">More Jokes</button>
    </form>
@* This is the button that when pressed will generate two new jokes on the page *@
</div>